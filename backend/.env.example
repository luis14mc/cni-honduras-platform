# Copy to ``backend/.env`` and adjust for your machine.
# Local development with docker-compose PostGIS: host ``localhost``, port ``5432``.

DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

DATABASE_URL=postgis://cni_user:cni_pass@localhost:5432/cni_db

# TEMPORARY Windows fallback if GDAL/GEOS aren't installed yet:
# DJANGO_ENABLE_GIS=False

DJANGO_LANGUAGE_CODE=es-hn
DJANGO_TIME_ZONE=America/Tegucigalpa

DJANGO_STATIC_URL=/static/
DJANGO_STATIC_ROOT_REL=staticfiles
DJANGO_MEDIA_URL=/media/
DJANGO_MEDIA_ROOT_REL=media

# Next.js (dev)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_ALLOW_CREDENTIALS=True
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# GeoDjango (Windows + OSGeo4W optional): uncomment and point to installed DLLs after ``OSGeo4W Shell`` confirms versions.
# DJANGO_GDAL_LIBRARY_PATH=C:\\OSGeo4W\\bin\\gdal312.dll
# DJANGO_GEOS_LIBRARY_PATH=C:\\OSGeo4W\\bin\\geos_c.dll

# Production / reverse proxy (optional; used by ``config.settings.production``)
# DJANGO_USE_SECURE_PROXY_HEADERS=False
# DJANGO_SESSION_COOKIE_SECURE=False
# DJANGO_CSRF_COOKIE_SECURE=False
# DJANGO_SECURE_SSL_REDIRECT=False
